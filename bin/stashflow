#!/usr/bin/env python3
"""Terminal UI for maintaining Stash subscription YAML files."""

from __future__ import annotations

import argparse
import curses
import shutil
import sys
from dataclasses import dataclass
from importlib.machinery import SourceFileLoader
from pathlib import Path
from types import ModuleType


SCRIPT_DIR = Path(__file__).resolve().parent
CLEANER_PATH = SCRIPT_DIR / "stashflow-clean"


@dataclass
class Target:
    path: Path
    result: object | None = None
    split_result: object | None = None
    error: str | None = None

    @property
    def bad_count(self) -> int:
        if self.result is None:
            return 0
        return len(self.result.removals)

    @property
    def reference_count(self) -> int:
        if self.result is None:
            return 0
        return self.result.reference_count

    @property
    def split_needed(self) -> bool:
        return self.split_result is not None and self.split_result.changed

    @property
    def needs_work(self) -> bool:
        return self.bad_count > 0 or self.split_needed


class App:
    def __init__(self, cleaner: ModuleType, paths: list[Path], backup: bool) -> None:
        self.cleaner = cleaner
        self.paths = paths
        self.backup = backup
        self.targets: list[Target] = []
        self.selected = 0
        self.offset = 0
        self.log = "Ready"
        self.refresh()

    def refresh(self) -> None:
        self.targets = [self.analyze(path) for path in self.paths]
        if self.selected >= len(self.targets):
            self.selected = max(0, len(self.targets) - 1)
        self.log = f"Scanned {len(self.targets)} file(s)"

    def analyze(self, path: Path) -> Target:
        target = Target(path=path)
        try:
            text = path.read_text(encoding="utf-8")
            target.result = self.cleaner.clean_text(text)
            target.split_result = self.cleaner.apply_stash_split_rules(target.result.text)
        except OSError as exc:
            target.error = str(exc)
        except UnicodeError as exc:
            target.error = f"UTF-8 read failed: {exc}"
        return target

    def fix_target(self, target: Target) -> str:
        try:
            original = target.path.read_text(encoding="utf-8")
        except OSError as exc:
            return f"{target.path.name}: skipped ({exc})"
        except UnicodeError as exc:
            return f"{target.path.name}: skipped (UTF-8 read failed: {exc})"

        clean_result = self.cleaner.clean_text(original)
        split_result = self.cleaner.apply_stash_split_rules(clean_result.text)
        final_text = split_result.text

        if final_text == original:
            return f"{target.path.name}: already clean and split rules are applied"

        if self.backup:
            backup = self.cleaner.backup_path(target.path)
            shutil.copy2(target.path, backup)
        else:
            backup = None

        target.path.write_text(final_text, encoding="utf-8")
        parts: list[str] = []
        if clean_result.removals:
            parts.append(f"removed {len(clean_result.removals)} proxy/proxies")
            parts.append(f"{clean_result.reference_count} reference(s)")
        if split_result.changed:
            parts.append(f"applied split rules ({split_result.group_count} groups, {split_result.rule_count} rules)")
        message = f"{target.path.name}: " + "; ".join(parts)
        if backup is not None:
            message += f"; backup {backup.name}"
        return message

    def clean_target(self, target: Target) -> str:
        if target.result is None:
            return f"{target.path.name}: skipped ({target.error})"
        if not target.result.removals:
            return f"{target.path.name}: no invalid uuid proxies"

        if self.backup:
            backup = self.cleaner.backup_path(target.path)
            shutil.copy2(target.path, backup)
        else:
            backup = None

        target.path.write_text(target.result.text, encoding="utf-8")
        message = (
            f"{target.path.name}: removed {len(target.result.removals)} proxy/proxies "
            f"and {target.result.reference_count} reference(s)"
        )
        if backup is not None:
            message += f"; backup {backup.name}"
        return message

    def clean_selected(self) -> None:
        if not self.targets:
            self.log = "No files"
            return
        target = self.targets[self.selected]
        message = self.fix_target(target)
        self.refresh()
        self.log = message

    def clean_all(self) -> None:
        dirty = [target for target in self.targets if target.needs_work]
        if not dirty:
            self.log = "No work needed"
            return
        messages = [self.fix_target(target) for target in dirty]
        self.refresh()
        self.log = f"Cleaned {len(messages)} file(s)"


def load_cleaner() -> ModuleType:
    if not CLEANER_PATH.exists():
        raise SystemExit(f"Cleaner script not found: {CLEANER_PATH}")
    return SourceFileLoader("bad_uuid_cleaner", str(CLEANER_PATH)).load_module()


def discover_files(args: list[str]) -> list[Path]:
    if args:
        return [Path(arg).expanduser() for arg in args]

    files: list[Path] = []
    for pattern in ("*.yaml", "*.yml"):
        files.extend(path for path in Path.cwd().glob(pattern) if path.is_file())
    return sorted(set(files), key=lambda path: str(path))


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Interactive TUI for cleaning bad UUID proxies and applying Stash split rules.")
    parser.add_argument("files", nargs="*", help="YAML files to scan. Defaults to *.yaml and *.yml in cwd.")
    parser.add_argument("--no-backup", action="store_true", help="do not create a .bak file before editing")
    return parser


def safe_add(win: curses.window, y: int, x: int, text: object, attr: int = 0) -> None:
    height, width = win.getmaxyx()
    if y < 0 or y >= height or x < 0 or x >= width:
        return
    try:
        win.addnstr(y, x, str(text), max(0, width - x - 1), attr)
    except curses.error:
        pass


def confirm(stdscr: curses.window, message: str) -> bool:
    height, width = stdscr.getmaxyx()
    prompt = f"{message}  y/N"
    box_width = min(max(len(prompt) + 4, 36), max(36, width - 4))
    y = max(0, height // 2 - 2)
    x = max(0, (width - box_width) // 2)
    attr = curses.A_REVERSE

    safe_add(stdscr, y, x, " " * box_width, attr)
    safe_add(stdscr, y + 1, x, " " * box_width, attr)
    safe_add(stdscr, y + 2, x, " " * box_width, attr)
    safe_add(stdscr, y + 1, x + 2, prompt, attr)
    stdscr.refresh()

    key = stdscr.getch()
    return key in (ord("y"), ord("Y"))


def draw(stdscr: curses.window, app: App) -> None:
    stdscr.erase()
    height, width = stdscr.getmaxyx()

    if height < 12 or width < 60:
        safe_add(stdscr, 0, 0, "Terminal is too small. Resize to at least 60x12.")
        stdscr.refresh()
        return

    header_attr = curses.color_pair(1) | curses.A_BOLD
    selected_attr = curses.color_pair(2) | curses.A_BOLD
    bad_attr = curses.color_pair(3) | curses.A_BOLD
    dim_attr = curses.color_pair(4)
    ok_attr = curses.color_pair(5)

    total_bad = sum(target.bad_count for target in app.targets)
    total_split = sum(1 for target in app.targets if target.split_needed)
    total_refs = sum(target.reference_count for target in app.targets)
    backup_label = "ON" if app.backup else "OFF"

    safe_add(stdscr, 0, 0, " Stash Subscription TUI ", header_attr)
    safe_add(
        stdscr,
        1,
        0,
        f" Files: {len(app.targets)} | Bad proxies: {total_bad} | Need split: {total_split} | References: {total_refs} | Backup: {backup_label}",
        dim_attr,
    )
    safe_add(stdscr, 2, 0, " Up/Down j/k move | Enter fix selected | A fix all | b toggle backup | r refresh | q quit", dim_attr)

    list_width = max(34, min(width // 2, 58))
    detail_x = list_width + 2
    list_top = 4
    list_height = height - 7

    safe_add(stdscr, 3, 0, "Files", curses.A_BOLD)
    safe_add(stdscr, 3, detail_x, "Preview", curses.A_BOLD)

    if not app.targets:
        safe_add(stdscr, list_top, 0, "No YAML files found.", bad_attr)
    else:
        if app.selected < app.offset:
            app.offset = app.selected
        if app.selected >= app.offset + list_height:
            app.offset = app.selected - list_height + 1

        visible = app.targets[app.offset : app.offset + list_height]
        for row, target in enumerate(visible, start=list_top):
            index = app.offset + row - list_top
            marker = ">" if index == app.selected else " "
            if target.error:
                status = "ERR"
                attr = bad_attr
            elif target.bad_count and target.split_needed:
                status = f"{target.bad_count:>2}+split"
                attr = bad_attr
            elif target.bad_count:
                status = f"{target.bad_count:>3} bad"
                attr = bad_attr
            elif target.split_needed:
                status = " split"
                attr = bad_attr
            else:
                status = " OK"
                attr = ok_attr
            if index == app.selected:
                attr = selected_attr
            safe_add(stdscr, row, 0, f"{marker} {status:<7} {target.path.name}", attr)

    selected = app.targets[app.selected] if app.targets else None
    if selected is not None:
        detail_width = width - detail_x - 1
        if selected.error:
            safe_add(stdscr, list_top, detail_x, selected.error, bad_attr)
        elif selected.result is not None:
            row = list_top
            if selected.bad_count:
                safe_add(
                    stdscr,
                    row,
                    detail_x,
                    f"{selected.bad_count} invalid uuid proxy/proxies, {selected.reference_count} group reference(s)",
                    bad_attr,
                )
                row += 1
                max_preview = max(0, height - row - 5)
                for removal in selected.result.removals[:max_preview]:
                    uuid = removal.uuid
                    if len(uuid) > 28:
                        uuid = uuid[:25] + "..."
                    safe_add(stdscr, row, detail_x, f"line {removal.line:<4} {removal.name}  uuid={uuid}")
                    row += 1
                if len(selected.result.removals) > max_preview:
                    safe_add(stdscr, row, detail_x, f"... {len(selected.result.removals) - max_preview} more", dim_attr)
                    row += 1

            if selected.split_needed and selected.split_result is not None:
                safe_add(
                    stdscr,
                    row,
                    detail_x,
                    f"Stash split rules need apply: {selected.split_result.group_count} groups, {selected.split_result.rule_count} rules",
                    bad_attr,
                )
                row += 1
                for name in getattr(app.cleaner, "STASH_SPLIT_GROUP_NAMES", [])[: max(0, height - row - 4)]:
                    safe_add(stdscr, row, detail_x, f"- {name}")
                    row += 1

            if not selected.bad_count and not selected.split_needed:
                safe_add(stdscr, row, detail_x, "No work needed. Bad UUID clean, split rules applied.", ok_attr)
        else:
            safe_add(stdscr, list_top, detail_x, "No invalid uuid proxies found.", ok_attr)
        if detail_width > 0:
            safe_add(stdscr, height - 4, detail_x, f"Path: {selected.path}", dim_attr)

    safe_add(stdscr, height - 2, 0, "-" * (width - 1), dim_attr)
    safe_add(stdscr, height - 1, 0, app.log, dim_attr)
    stdscr.refresh()


def run_tui(stdscr: curses.window, app: App) -> None:
    try:
        curses.curs_set(0)
    except curses.error:
        pass
    stdscr.keypad(True)
    if curses.has_colors():
        curses.start_color()
        try:
            curses.use_default_colors()
            default_bg = -1
        except curses.error:
            default_bg = curses.COLOR_BLACK
        curses.init_pair(1, curses.COLOR_BLACK, curses.COLOR_CYAN)
        curses.init_pair(2, curses.COLOR_BLACK, curses.COLOR_WHITE)
        curses.init_pair(3, curses.COLOR_RED, default_bg)
        curses.init_pair(4, curses.COLOR_BLUE, default_bg)
        curses.init_pair(5, curses.COLOR_GREEN, default_bg)

    while True:
        draw(stdscr, app)
        key = stdscr.getch()

        if key in (ord("q"), ord("Q"), 27):
            return
        if key in (curses.KEY_UP, ord("k"), ord("K")):
            app.selected = max(0, app.selected - 1)
        elif key in (curses.KEY_DOWN, ord("j"), ord("J")):
            app.selected = min(max(0, len(app.targets) - 1), app.selected + 1)
        elif key in (ord("r"), ord("R")):
            app.refresh()
        elif key in (ord("b"), ord("B")):
            app.backup = not app.backup
            app.log = f"Backup {'ON' if app.backup else 'OFF'}"
        elif key in (curses.KEY_ENTER, 10, 13):
            if app.targets:
                target = app.targets[app.selected]
                if not target.needs_work:
                    app.log = f"{target.path.name}: no work needed"
                elif confirm(stdscr, f"Fix {target.path.name}?"):
                    app.clean_selected()
                else:
                    app.log = "Canceled"
        elif key == ord("A"):
            dirty_count = sum(1 for target in app.targets if target.needs_work)
            if dirty_count == 0:
                app.log = "No work needed"
            elif confirm(stdscr, f"Fix all {dirty_count} file(s)?"):
                app.clean_all()
            else:
                app.log = "Canceled"


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    cleaner = load_cleaner()
    paths = discover_files(args.files)
    app = App(cleaner=cleaner, paths=paths, backup=not args.no_backup)
    curses.wrapper(run_tui, app)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
