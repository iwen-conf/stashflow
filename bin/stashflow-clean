#!/usr/bin/env python3
"""
Maintain Clash/Mihomo/Stash subscription files.

This script can remove proxy entries whose uuid value is not a canonical UUID,
and can re-apply a local Stash split-routing template after subscription updates.

The script intentionally works on text instead of re-serializing YAML. Some
subscription files use flow-style maps with unquoted colons in node names, which
strict YAML parsers may reject even though clients accept them.
"""

from __future__ import annotations

import argparse
import re
import shutil
import sys
from dataclasses import dataclass
from pathlib import Path


UUID_RE = re.compile(
    r"^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
)


@dataclass(frozen=True)
class Removal:
    name: str
    line: int
    uuid: str


@dataclass
class CleanResult:
    text: str
    removals: list[Removal]
    reference_count: int


@dataclass
class SplitResult:
    text: str
    changed: bool
    group_count: int
    rule_count: int


