def leading_spaces(line: str) -> int:
    return len(line) - len(line.lstrip(" "))


def section_bounds(lines: list[str], section_name: str) -> tuple[int, int] | None:
    pattern = re.compile(rf"^{re.escape(section_name)}:\s*(?:#.*)?$")
    top_level_key = re.compile(r"^[^\s#-][^:]*:\s*")
    for start, line in enumerate(lines):
        if pattern.match(line):
            end = len(lines)
            for i in range(start + 1, len(lines)):
                if lines[i].strip() and top_level_key.match(lines[i]):
                    end = i
                    break
            return start, end
    return None


def item_bounds(lines: list[str], item_start: int, section_end: int) -> tuple[int, int]:
    indent = leading_spaces(lines[item_start])
    end = section_end
    for i in range(item_start + 1, section_end):
        line = lines[i]
        if line.startswith(" " * indent + "- ") and leading_spaces(line) == indent:
            end = i
            break
    return item_start, end


def parse_inline_value(text: str, key: str) -> str | None:
    pattern = re.compile(rf"(?:^|[{{,\s]){re.escape(key)}:\s*([^,}}\n]+)")
    match = pattern.search(text)
    if not match:
        return None
    return unquote(match.group(1).strip())


def parse_block_value(lines: list[str], key: str) -> str | None:
    pattern = re.compile(rf"^\s*{re.escape(key)}:\s*(.+?)\s*(?:#.*)?$")
    for line in lines:
        match = pattern.match(line)
        if match:
            return unquote(match.group(1).strip())
    return None


def unquote(value: str) -> str:
    if len(value) >= 2 and value[0] == value[-1] and value[0] in {"'", '"'}:
        return value[1:-1]
    return value


def proxy_name(item_lines: list[str]) -> str | None:
    text = "\n".join(item_lines)
    return parse_inline_value(text, "name") or parse_block_value(item_lines, "name")


def proxy_uuid(item_lines: list[str]) -> str | None:
    text = "\n".join(item_lines)
    return parse_inline_value(text, "uuid") or parse_block_value(item_lines, "uuid")


def remove_bad_proxy_items(lines: list[str]) -> tuple[list[str], list[Removal]]:
    bounds = section_bounds(lines, "proxies")
    if bounds is None:
        return lines, []

    section_start, section_end = bounds
    removals: list[Removal] = []
    remove_ranges: list[tuple[int, int]] = []

    i = section_start + 1
    while i < section_end:
        if lines[i].lstrip().startswith("- "):
            start, end = item_bounds(lines, i, section_end)
            item = lines[start:end]
            uuid = proxy_uuid(item)
            if uuid is not None and not UUID_RE.fullmatch(uuid):
                name = proxy_name(item) or f"<unnamed:{start + 1}>"
                removals.append(Removal(name=name, line=start + 1, uuid=uuid))
                remove_ranges.append((start, end))
            i = end
        else:
            i += 1

    if not remove_ranges:
        return lines, removals

    keep = [True] * len(lines)
    for start, end in remove_ranges:
        for index in range(start, end):
            keep[index] = False
    return [line for index, line in enumerate(lines) if keep[index]], removals


def remove_references(lines: list[str], names: set[str]) -> tuple[list[str], int]:
    if not names:
        return lines, 0

    removed = 0
    output: list[str] = []
    flow_list_pattern = re.compile(r"^(?P<prefix>\s*proxies:\s*)\[(?P<body>.*)\](?P<suffix>\s*(?:#.*)?)$")

    for line in lines:
        stripped = line.strip()
        if stripped.startswith("- "):
            value = unquote(stripped[2:].strip())
            if value in names:
                removed += 1
                continue

        match = flow_list_pattern.match(line)
        if match:
            body = match.group("body")
            items = [item.strip() for item in body.split(",")]
            kept_items = []
            for item in items:
                if not item:
                    continue
                if unquote(item) in names:
                    removed += 1
                else:
                    kept_items.append(item)
            line = f"{match.group('prefix')}[{', '.join(kept_items)}]{match.group('suffix')}"

        output.append(line)

    return output, removed


def clean_text(text: str) -> CleanResult:
    has_trailing_newline = text.endswith("\n")
    lines = text.splitlines()

    lines, removals = remove_bad_proxy_items(lines)
    names = {removal.name for removal in removals}
    lines, reference_count = remove_references(lines, names)

    cleaned = "\n".join(lines)
    if has_trailing_newline:
        cleaned += "\n"

    return CleanResult(text=cleaned, removals=removals, reference_count=reference_count)


def remove_proxy_groups_by_name(lines: list[str], names: set[str]) -> list[str]:
    bounds = section_bounds(lines, "proxy-groups")
    if bounds is None:
        return lines

    section_start, section_end = bounds
    remove_ranges: list[tuple[int, int]] = []

    i = section_start + 1
    while i < section_end:
        if leading_spaces(lines[i]) == 0 and lines[i].lstrip().startswith("- "):
            start, end = item_bounds(lines, i, section_end)
            name = proxy_name(lines[start:end])
            if name in names:
                remove_ranges.append((start, end))
            i = end
        else:
            i += 1

    if not remove_ranges:
        return lines

    keep = [True] * len(lines)
    for start, end in remove_ranges:
        for index in range(start, end):
            keep[index] = False
    return [line for index, line in enumerate(lines) if keep[index]]


def insert_stash_split_groups(lines: list[str]) -> list[str]:
    groups_bounds = section_bounds(lines, "proxy-groups")
    if groups_bounds is None:
        rules_bounds = section_bounds(lines, "rules")
        insert_at = rules_bounds[0] if rules_bounds is not None else len(lines)
        return lines[:insert_at] + ["proxy-groups:"] + STASH_SPLIT_GROUP_LINES + lines[insert_at:]

    insert_at = groups_bounds[1]
    return lines[:insert_at] + STASH_SPLIT_GROUP_LINES + lines[insert_at:]


def replace_rules(lines: list[str]) -> list[str]:
    replacement = ["rules:"] + STASH_RULE_LINES
    bounds = section_bounds(lines, "rules")
    if bounds is None:
        return lines + replacement
    start, end = bounds
    return lines[:start] + replacement + lines[end:]


def apply_stash_split_rules(text: str) -> SplitResult:
    has_trailing_newline = text.endswith("\n")
    lines = text.splitlines()
    lines = remove_proxy_groups_by_name(lines, set(STASH_SPLIT_GROUP_NAMES))
    lines = insert_stash_split_groups(lines)
    lines = replace_rules(lines)

    updated = "\n".join(lines)
    if has_trailing_newline:
        updated += "\n"

    return SplitResult(
        text=updated,
        changed=updated != text,
        group_count=len(STASH_SPLIT_GROUP_NAMES),
        rule_count=len(STASH_RULE_LINES),
    )


def backup_path(path: Path) -> Path:
    candidate = path.with_name(path.name + ".bak")
    if not candidate.exists():
        return candidate

    index = 1
    while True:
        candidate = path.with_name(f"{path.name}.bak{index}")
        if not candidate.exists():
            return candidate
        index += 1


def clean_file(path: Path, *, dry_run: bool, backup: bool, apply_stash_rules: bool = False) -> int:
    original = path.read_text(encoding="utf-8")
    result = clean_text(original)
    final_text = result.text
    split_result: SplitResult | None = None

    if apply_stash_rules:
        split_result = apply_stash_split_rules(final_text)
        final_text = split_result.text

    changed = final_text != original
    if not changed:
        if apply_stash_rules:
            print(f"{path}: no invalid uuid proxies found; stash split rules already applied")
        else:
            print(f"{path}: no invalid uuid proxies found")
        return 0

    if result.removals:
        print(f"{path}: removing {len(result.removals)} invalid uuid proxy/proxies")
        for removal in result.removals:
            print(f"  line {removal.line}: {removal.name} (uuid: {removal.uuid})")
        print(f"  removed {result.reference_count} proxy-group reference(s)")
    else:
        print(f"{path}: no invalid uuid proxies found")

    if split_result is not None:
        if split_result.changed:
            print(f"  applied stash split rules ({split_result.group_count} groups, {split_result.rule_count} rules)")
        else:
            print("  stash split rules already applied")

    if dry_run:
        print("  dry run: file not changed")
        return 0

    if backup:
        target = backup_path(path)
        shutil.copy2(path, target)
        print(f"  backup: {target}")

    path.write_text(final_text, encoding="utf-8")
    print("  updated")
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Clean invalid UUID proxies and re-apply the built-in Stash split-routing template.",
    )
    parser.add_argument("files", nargs="+", type=Path, help="YAML files to clean")
    parser.add_argument("--dry-run", action="store_true", help="show what would be removed without editing files")
    parser.add_argument("--no-backup", action="store_true", help="do not create a .bak file before editing")
    parser.add_argument("--apply-stash-rules", action="store_true", help="re-apply the built-in Stash split-routing template")
    parser.add_argument("--fix-all", action="store_true", help="clean invalid uuid proxies and re-apply Stash split rules")
    return parser


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    status = 0
    for path in args.files:
        if not path.exists():
            print(f"{path}: file not found", file=sys.stderr)
            status = 1
            continue
        if not path.is_file():
            print(f"{path}: not a file", file=sys.stderr)
            status = 1
            continue
        try:
            status |= clean_file(
                path,
                dry_run=args.dry_run,
                backup=not args.no_backup,
                apply_stash_rules=args.apply_stash_rules or args.fix_all,
            )
        except OSError as exc:
            print(f"{path}: {exc}", file=sys.stderr)
            status = 1
    return status


if __name__ == "__main__":
    raise SystemExit(main())
